# Load shared shell functions and PATH for interactive non-login shells.
if [ -r "$XDG_CONFIG_HOME/shell/functions.sh" ]; then
    source "$XDG_CONFIG_HOME/shell/functions.sh"
fi

if [ -r "$XDG_CONFIG_HOME/shell/path.sh" ]; then
    source "$XDG_CONFIG_HOME/shell/path.sh"
fi

# Load Zsh plugins
source $ZDOTDIR/plugins/antigen.zsh

# Load Zsh settings
source $ZDOTDIR/settings.zsh

# Load shell plugins
source $XDG_CONFIG_HOME/shell/plugins/homebrew-file.sh
# source $XDG_CONFIG_HOME/shell/plugins/claude-mem.sh

# Load zsh functions
for func in $ZDOTDIR/functions/*.zsh; do
    source "$func"
done

# Compatibility: some installers append zsh snippets to ~/.zshrc even though
# this setup uses ZDOTDIR=$XDG_CONFIG_HOME/zsh. Source it as an installer
# compatibility sink, not as canonical configuration.
if [ -r "$HOME/.zshrc" ] && [ -z "${PJB_SKIP_HOME_ZSHRC:-}" ]; then
    export PJB_SKIP_HOME_ZSHRC=1
    source "$HOME/.zshrc"
    unset PJB_SKIP_HOME_ZSHRC
fi

# Allow local customization
if [ -e $XDG_CONFIG_HOME/local/zsh/zshrc ]; then
    source $XDG_CONFIG_HOME/local/zsh/zshrc
fi
